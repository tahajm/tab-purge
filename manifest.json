{
  "manifest_version": 3,
  "name": "Close Tabs by Domain",
  "version": "1.1",
  "description": "Manage a list of domains and close tabs for each domain",
  "permissions": ["tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Close Tabs by Domain"
  },
  "icons": {
  "16": "icons/icon16.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
}
}
