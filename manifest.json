{
  "manifest_version": 3,
  "name": "TabPurge",
  "version": "1.2",
  "description": "Manage a list of domains and close all matching tabs in the current window with one click.",
  "minimum_chrome_version": "102",
  "permissions": ["tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TabPurge"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
