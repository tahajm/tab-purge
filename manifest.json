{
  "manifest_version": 3,
  "name": "TabPurge",
  "version": "1.1",
  "description": "Manage a list of domains and close all matching tabs instantly",
  "permissions": ["tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TabPurge"
  },
  "icons": {
  "16": "icons/icon16.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
}
}
