{
  "manifest_version": 3,
  "name": "Close GitLab Tabs",
  "version": "1.0",
  "description": "Closes all open tabs with the domain gitlab.com",
  "permissions": ["tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Close GitLab Tabs"
  }
}
